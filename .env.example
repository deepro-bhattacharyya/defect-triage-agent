# --- LLM & embeddings ---
# This POC standardizes on Google Gemini for BOTH the LLM (gemini-1.5-flash) and
# embeddings (gemini-embedding-001). One key covers both. (OpenAI is blocked on the
# corporate network and is not used.)
GOOGLE_API_KEY=

# --- Corporate TLS proxy (optional) ---
# If your network intercepts TLS, Python's certifi store won't trust the proxy CA
# and SDK calls fail with CERTIFICATE_VERIFY_FAILED. Export your OS root store to a
# PEM bundle (see INSTALL.md) and point here; the app auto-detects certs/corp-ca-bundle.pem.
# CORP_CA_BUNDLE=./certs/corp-ca-bundle.pem

# --- Jira ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Slack ---
SLACK_WEBHOOK_URL=

# --- Vector store ---
VECTOR_BACKEND=chroma            # chroma | pinecone
CHROMA_PERSIST_DIR=./.chroma
# PINECONE_API_KEY=
# PINECONE_INDEX=defect-triage

# --- Tracing / monitoring ---
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=defect-triage-agent
# SENTRY_DSN=

# --- Tunables (defaults match the plan) ---
SIMILARITY_THRESHOLD=0.88
MAX_IMAGE_MB=5
MAX_IMAGES=3

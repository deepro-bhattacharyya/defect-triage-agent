# --- LLM & embeddings ---
# Claude Sonnet 4.6 is the PRODUCTION LLM. Gemini 1.5 Flash is for LOCAL DEV ONLY.
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- Jira ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Slack ---
SLACK_WEBHOOK_URL=

# --- Vector store ---
VECTOR_BACKEND=chroma            # chroma | pinecone
CHROMA_PERSIST_DIR=./.chroma
# PINECONE_API_KEY=
# PINECONE_INDEX=defect-triage

# --- Tracing / monitoring ---
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=defect-triage-agent
# SENTRY_DSN=

# --- Tunables (defaults match the plan) ---
SIMILARITY_THRESHOLD=0.88
MAX_IMAGE_MB=5
MAX_IMAGES=3
